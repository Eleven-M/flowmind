{
  "ai": {
    "enabled": true,
    "defaultProvider": "glm",
    "fallbackToRules": true,
    "providers": {
      "openai": {
        "apiKey": "${OPENAI_API_KEY}",
        "model": "gpt-4",
        "temperature": 0.3,
        "maxTokens": 2000
      },
      "anthropic": {
        "apiKey": "${ANTHROPIC_API_KEY}",
        "model": "claude-3-sonnet-20240229",
        "maxTokens": 2000,
        "temperature": 0.3
      },
      "glm": {
        "apiKey": "${ZHIPU_API_KEY}",
        "model": "glm-4-flash",
        "temperature": 0.3,
        "maxTokens": 2000
      },
      "mimo": {
        "apiKey": "${MIMO_API_KEY}",
        "model": "mimo-7b",
        "temperature": 0.3,
        "maxTokens": 2000
      },
      "qwen": {
        "apiKey": "${DASHSCOPE_API_KEY}",
        "model": "qwen-turbo",
        "temperature": 0.3,
        "maxTokens": 2000
      },
      "ernie": {
        "apiKey": "${BAIDU_API_KEY}",
        "secretKey": "${BAIDU_SECRET_KEY}",
        "model": "ernie-4.0-turbo-8k",
        "temperature": 0.3,
        "maxTokens": 2000
      },
      "deepseek": {
        "apiKey": "${DEEPSEEK_API_KEY}",
        "model": "deepseek-chat",
        "temperature": 0.3,
        "maxTokens": 2000
      },
      "ollama": {
        "baseUrl": "http://localhost:11434",
        "model": "llama2",
        "temperature": 0.3
      }
    },
    "features": {
      "intentUnderstanding": true,
      "parameterExtraction": true,
      "skillSelection": true,
      "resultSummary": true,
      "learningFeedback": true
    }
  }
}
